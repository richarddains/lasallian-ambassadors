// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  AMBASSADOR
  COORDINATOR
  LEAD
  ADMIN
}

enum Order {
  CORE
  ASPIRING_CORE
  NON_FIRST_TIMERS
  FIRST_TIMERS
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
  WAITLISTED
}

enum TaskStatus {
  OPEN
  ASSIGNED
  COMPLETED
}

// User profile linked to Supabase Auth user
model Profile {
  id                String    @id @default(cuid())
  userId            String    @unique // Supabase Auth user ID
  email             String    @unique
  firstName         String
  lastName          String
  bio               String?
  avatarUrl         String?
  batch             Int? // Year joined (e.g., 2023)
  order             Order? // Core, Aspiring Core, Non-First Timers, First Timers
  role              Role      @default(AMBASSADOR)
  isActive          Boolean   @default(true)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  registrations     EventRegistration[]
  assignedTasks     Task[]
  createdEvents     Event[]

  @@index([userId])
  @@index([email])
  @@index([role])
}

// Event created by coordinators/leads
model Event {
  id                String    @id @default(cuid())
  title             String
  description       String
  location          String
  startTime         DateTime
  endTime           DateTime
  bannerUrl         String?
  slots             Int?      // null = unlimited slots
  status            EventStatus @default(DRAFT)
  requiresApproval  Boolean   @default(false)
  createdById       String
  createdBy         Profile   @relation(fields: [createdById], references: [id])

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  registrations     EventRegistration[]
  tasks             Task[]

  @@index([status])
  @@index([createdById])
  @@index([startTime])
}

// Ambassador sign-ups for events
model EventRegistration {
  id                String    @id @default(cuid())
  eventId           String
  event             Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  profileId         String
  profile           Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  status            RegistrationStatus @default(PENDING)
  registeredAt      DateTime  @default(now())
  approvedAt        DateTime?
  rejectionReason   String?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([eventId, profileId])
  @@index([status])
  @@index([eventId])
  @@index([profileId])
}

// Tasks for ambassadors (linked to events or standalone)
model Task {
  id                String    @id @default(cuid())
  title             String
  description       String
  eventId           String?   // null if standalone task
  event             Event?    @relation(fields: [eventId], references: [id], onDelete: SetNull)
  assignedToId      String
  assignedTo        Profile   @relation(fields: [assignedToId], references: [id])
  status            TaskStatus @default(OPEN)
  dueDate           DateTime?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status])
  @@index([assignedToId])
  @@index([eventId])
}
