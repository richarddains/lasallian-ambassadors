// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  AMBASSADOR
  ASPIRING_CORE
  CORE
}

enum Order {
  CORE
  ASPIRING_CORE
  NON_FIRST_TIMERS
  FIRST_TIMERS
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum RegistrationStatus {
  APPROVED
  WAITLISTED
}

enum EventType {
  ADMIN_REQUEST
  LAMB_MODULE
  LAMB_EVENT
  MAJOR_EVENT
}

enum VolunteerType {
  LAMB
  DOCULAMB
}

enum Attire {
  DAY1_UNIFORM
  DAY2_UNIFORM
  USHERING_ATTIRE
  GAWAD_LASALYANO
}

enum Attendance {
  PRESENT
  ABSENT
  EXCUSED
}

enum Committee {
  MARKETING_RELATIONS
  HUMAN_RESOURCE
  DOCUMENTATIONS_PUBLICITY
  OPERATIONS_FINANCE
}

// User profile linked to Supabase Auth user
model Profile {
  id                String    @id @default(cuid())
  userId            String    @unique // Supabase Auth user ID
  email             String    @unique
  firstName         String
  lastName          String
  bio               String?
  avatarUrl         String?
  batch             Int? // Year joined (e.g., 2023)
  order             Order? // Core, Aspiring Core, Non-First Timers, First Timers
  committee         Committee?
  role              Role      @default(AMBASSADOR)
  isActive          Boolean   @default(true)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  registrations     EventRegistration[]
  createdEvents     Event[]   @relation("EventCreatedBy")
  aicEvents         Event[]   @relation("EventAIC")

  @@index([userId])
  @@index([email])
  @@index([role])
}

// Event created by coordinators/leads
model Event {
  id                String    @id @default(cuid())
  title             String
  description       String
  location          String
  startTime         DateTime
  endTime           DateTime
  bannerUrl         String?
  eventType         EventType @default(ADMIN_REQUEST)
  slots             Int?      // null = unlimited slots (total)
  lambSlots         Int?      // null = unlimited
  docuLambSlots     Int?      // null = unlimited
  status            EventStatus @default(DRAFT)
  attire            Attire?
  createdById       String
  createdBy         Profile   @relation("EventCreatedBy", fields: [createdById], references: [id])
  aicId             String?
  aic               Profile?  @relation("EventAIC", fields: [aicId], references: [id])

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  registrations     EventRegistration[]

  @@index([status])
  @@index([createdById])
  @@index([aicId])
  @@index([startTime])
}

// Ambassador sign-ups for events
model EventRegistration {
  id                String    @id @default(cuid())
  eventId           String
  event             Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  profileId         String
  profile           Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  status            RegistrationStatus @default(APPROVED)
  volunteerType     VolunteerType?
  registeredAt      DateTime  @default(now())
  approvedAt        DateTime?
  rejectionReason   String?
  cancellationReason          String?
  cancellationRequestedAt     DateTime?
  attendance                  Attendance?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([eventId, profileId])
  @@index([status])
  @@index([eventId])
  @@index([profileId])
}

